# =============================================================================
# RuneBolt Backend — Production Environment Variables
# =============================================================================
# Copy this file to .env and fill in all values before deploying.
# Lines marked [REQUIRED] must be set. Lines marked [OPTIONAL] have defaults.

# ==================== Server ====================

# [OPTIONAL] Port the server listens on (default: 3141)
PORT=3141

# [REQUIRED] Must be "production" for production deployments
NODE_ENV=production

# ==================== Database ====================

# [REQUIRED] PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://runebolt:CHANGE_ME@localhost:5432/runebolt

# [OPTIONAL] Connection pool settings
DB_POOL_MAX=50
DB_POOL_MIN=10
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000
DB_STATEMENT_TIMEOUT=10000

# ==================== Redis ====================

# [OPTIONAL] Redis host and port for caching (default: localhost:6379)
# Server runs in no-cache mode if Redis is unavailable
REDIS_HOST=localhost
REDIS_PORT=6379

# ==================== Authentication ====================

# [REQUIRED] JWT signing secret — must be 64+ hex characters
# Generate with: openssl rand -hex 32
# CRITICAL: Never reuse across environments. Rotate periodically.
JWT_SECRET=

# ==================== CORS ====================

# [REQUIRED] Comma-separated list of allowed origins
# Example: https://app.runebolt.io,https://runebolt.io
# CORS is locked down in production — requests from unlisted origins are blocked
CORS_ORIGIN=https://app.runebolt.io

# ==================== Bitcoin ====================

# [OPTIONAL] Bitcoin network: mainnet or testnet (default: mainnet)
BITCOIN_NETWORK=mainnet

# [OPTIONAL] Mempool API URL for fee estimation and tx broadcasting
# Default: https://mempool.space/api
MEMPOOL_API_URL=https://mempool.space/api

# [OPTIONAL] Bitcoin RPC URL (if using direct RPC instead of Mempool API)
BITCOIN_RPC_URL=

# ==================== Rate Limiting ====================

# [OPTIONAL] Rate limit window in milliseconds (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000

# [OPTIONAL] Max requests per window (default: 100)
RATE_LIMIT_MAX_REQUESTS=100

# ==================== Rune Configuration ====================

# [OPTIONAL] Rune ID to track (default: 1:0 for DOG)
RUNE_ID=1:0

# [OPTIONAL] Rune display name
RUNE_NAME=DOG•GO•TO•THE•MOON
