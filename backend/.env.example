# RuneBolt Backend Environment Configuration
# Copy this file to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development

# PostgreSQL Database
DATABASE_URL=postgresql://runebolt:runebolt@localhost:5432/runebolt
DB_POOL_MAX=50
DB_POOL_MIN=10
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000
DB_STATEMENT_TIMEOUT=10000

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Rate Limiting
RATE_LIMIT_ANON=30
RATE_LIMIT_AUTH=100
RATE_LIMIT_GLOBAL=10000

# Bitcoin
BITCOIN_RPC_URL=http://localhost:8332
BITCOIN_RPC_USER=
BITCOIN_RPC_PASS=
BITCOIN_NETWORK=mainnet

# Rune configuration
RUNE_ID=1:0
RUNE_NAME=DOG•GO•TO•THE•MOON

# JWT
JWT_SECRET=your-secret-key-here

# Logging
LOG_LEVEL=info
