# ── RuneBolt Configuration ──
# Copy this file to .env and fill in your values

# ── Bitcoin ──
BITCOIN_NETWORK=regtest              # mainnet | testnet | regtest
BITCOIN_RPC_URL=http://localhost:18443
BITCOIN_RPC_USER=bitcoin
BITCOIN_RPC_PASS=bitcoin

# ── Lightning (LND) ──
LND_HOST=localhost
LND_PORT=10009
LND_TLS_CERT=~/.lnd/tls.cert
LND_MACAROON=~/.lnd/data/chain/bitcoin/regtest/admin.macaroon

# ── Runes Indexer ──
ORD_API_URL=http://localhost:80      # ord server URL
UNISAT_API_URL=https://open-api.unisat.io
UNISAT_API_KEY=                      # Unisat API key (fallback indexer)

# ── Bridge Settings ──
BRIDGE_MODE=custodial                # custodial | non-custodial
BRIDGE_ADDRESS=                      # Bridge operator's Bitcoin address (for Runes inventory)
BRIDGE_PRIVKEY_PATH=                 # Path to bridge operator's private key file
HTLC_TIMEOUT_BLOCKS=144              # HTLC timeout (~24 hours on mainnet)
FEE_RATE_BPS=50                      # Bridge fee in basis points (50 = 0.5%)
MIN_SWAP_AMOUNT=1000                 # Minimum swap amount (Rune units)
MAX_SWAP_AMOUNT=100000000            # Maximum swap amount (Rune units)

# ── API Server ──
SERVER_PORT=3000
SERVER_HOST=0.0.0.0
CORS_ORIGINS=*                       # Comma-separated allowed origins

# ── Logging ──
LOG_LEVEL=info                       # debug | info | warn | error
