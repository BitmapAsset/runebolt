# =============================================================================
# RuneBolt Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# -----------------------------------------------------------------------------
# Voltage LND Node
# -----------------------------------------------------------------------------
# Your Voltage managed Lightning node credentials
VOLTAGE_REST_URL=https://your-node.m.voltageapp.io
VOLTAGE_MACAROON=<admin-macaroon-hex>

# Node identity (from `lncli getinfo`)
NODE_PUBKEY=<your-node-pubkey-hex>
NODE_ALIAS=runebolt-node

# Network: mainnet or testnet
NETWORK=testnet

# -----------------------------------------------------------------------------
# RuneBolt API Server
# -----------------------------------------------------------------------------
RUNEBOLT_PORT=3141
RUNEBOLT_FEE_RATE=0.003

# -----------------------------------------------------------------------------
# Unisat Open API (optional - for enhanced rate limits)
# -----------------------------------------------------------------------------
# Get an API key at https://open-api.unisat.io
# UNISAT_API_KEY=<your-unisat-api-key>

# -----------------------------------------------------------------------------
# CORS (production only)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins. Use * for development only.
# CORS_ORIGINS=https://runebolt.xyz,https://app.runebolt.xyz

# -----------------------------------------------------------------------------
# Bitcoin RPC (Docker deployment only)
# -----------------------------------------------------------------------------
# BITCOIN_RPC_HOST=bitcoind
# BITCOIN_RPC_PORT=8332
# BITCOIN_RPC_USER=runebolt
# BITCOIN_RPC_PASS=<rpc-password>

# -----------------------------------------------------------------------------
# LND (Docker deployment only - alternative to Voltage)
# -----------------------------------------------------------------------------
# LND_GRPC_HOST=lnd:10009
# LND_REST_HOST=lnd:8080
# LND_MACAROON_PATH=/lnd/data/chain/bitcoin/mainnet/admin.macaroon
# LND_TLS_CERT_PATH=/lnd/tls.cert
