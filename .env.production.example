# RuneBolt Production Environment Configuration
# Copy to .env.production and fill in actual values
# NEVER commit this file to version control!

# ============================================
# Application Settings
# ============================================
NODE_ENV=production
NETWORK=mainnet
VERSION=latest

# ============================================
# API Configuration
# ============================================
NEXT_PUBLIC_API_URL=https://api.runebolt.io
NEXT_PUBLIC_WS_URL=wss://ws.runebolt.io

# ============================================
# Security (CRITICAL - Change these!)
# ============================================
JWT_SECRET=change_me_to_a_secure_random_string_min_32_chars
POSTGRES_PASSWORD=change_me_to_a_secure_random_password
GRAFANA_ADMIN_PASSWORD=change_me_to_a_secure_password
VAULT_DEV_ROOT_TOKEN_ID=change_me_to_a_secure_token

# Bitcoin Keys (Handle with extreme care!)
RUNEBOLT_XPUB=your_xpub_here
RUNEBOLT_PRIVKEY=your_private_key_here_or_use_vault

# ============================================
# Database Configuration
# ============================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=runebolt
POSTGRES_USER=runebolt

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# Vault Configuration
# ============================================
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=

# ============================================
# External Services
# ============================================
MEMPOOL_API=https://mempool.space/api

# ============================================
# S3 Backup Configuration
# ============================================
S3_BUCKET=runebolt-backups
S3_REGION=us-east-1
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ============================================
# SMTP Configuration (for Grafana alerts)
# ============================================
GF_SMTP_ENABLED=false
GF_SMTP_HOST=smtp.gmail.com:587
GF_SMTP_USER=your-email@gmail.com
GF_SMTP_PASSWORD=your-app-password
GF_SMTP_FROM_ADDRESS=alerts@runebolt.io

# ============================================
# Notification Webhooks
# ============================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# ============================================
# Deployment Configuration
# ============================================
DEPLOY_HOST=your-server-ip-or-hostname
DEPLOY_USER=runebolt
DEPLOY_PATH=/opt/runebolt
