# RuneBolt Frontend Configuration
# Copy to .env.local and fill in your values.

# Backend API URL
# For Vercel deployment: leave empty (Vercel rewrites handle /api/* proxy)
# For local dev: http://localhost:3141
NEXT_PUBLIC_RUNEBOLT_API_URL=http://localhost:3141

# Network: testnet or mainnet
NEXT_PUBLIC_NETWORK=testnet
