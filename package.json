{
  "name": "runebolt",
  "version": "0.1.0",
  "description": "RuneBolt - Runes Lightning Bridge: Instant, trustless transfers of Bitcoin Runes tokens over the Lightning Network",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "runebolt": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/api/server.js",
    "dev": "ts-node src/api/server.ts",
    "cli": "ts-node src/cli/index.ts",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "lint": "eslint src/ tests/",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "bitcoin",
    "runes",
    "lightning",
    "bridge",
    "submarine-swap",
    "htlc",
    "atomic-swap"
  ],
  "author": "Block Genomics (blockgenomics.io) <gary-moto>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gary-moto/runebolt"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.9.0",
    "@grpc/proto-loader": "^0.7.10",
    "bitcoinjs-lib": "^6.1.5",
    "bolt11": "^1.4.1",
    "commander": "^11.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ecpair": "^2.1.0",
    "express": "^4.18.2",
    "pino": "^8.17.0",
    "tiny-secp256k1": "^2.2.3",
    "uuid": "^9.0.0",
    "ws": "^8.16.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
