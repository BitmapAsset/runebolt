{
  "name": "runebolt",
  "version": "1.0.0",
  "description": "RuneBolt - Self-sovereign Runes-over-Lightning bridge using Taproot Assets. Wallet software, not a service.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "runebolt": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/api/server.js",
    "dev": "ts-node src/api/server.ts",
    "cli": "ts-node src/cli/index.ts",
    "test": "jest --forceExit",
    "test:unit": "jest tests/unit --forceExit",
    "lint": "eslint src/ tests/",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "bitcoin",
    "runes",
    "lightning",
    "taproot-assets",
    "self-sovereign",
    "wallet",
    "ordinals",
    "bitmap"
  ],
  "author": "Block Genomics <gary-moto> (blockgenomics.io)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gary-moto/runebolt.git"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.7.15",
    "argon2": "^0.31.0",
    "bip32": "^4.0.0",
    "bip39": "^3.1.0",
    "bitcoinjs-lib": "^6.1.5",
    "bolt11": "^1.4.1",
    "commander": "^11.1.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "ecpair": "^2.1.0",
    "express": "^4.22.1",
    "pino": "^8.17.0",
    "tiny-secp256k1": "^2.2.3",
    "uuid": "^9.0.1",
    "ws": "^8.16.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/gary-moto/runebolt/issues"
  },
  "homepage": "https://github.com/gary-moto/runebolt#readme"
}
